{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"    // <-- ADD THIS LINE
  },
  "include": ["**/*.ts", "deploy/**/*.ts"],
  "exclude": ["node_modules"]
}